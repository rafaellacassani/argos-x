# =============================================
# ANTHROPIC (Claude AI)
# =============================================
ANTHROPIC_API_KEY=sk-ant-...

# =============================================
# STRIPE
# =============================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================
# GOOGLE (Sheets / Calendar)
# Crie uma Service Account no Google Cloud Console
# e compartilhe suas planilhas com o e-mail da conta
# =============================================
GOOGLE_SERVICE_ACCOUNT_EMAIL=financial-agent@seu-projeto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# IDs das planilhas (da URL do Google Sheets)
GOOGLE_SHEET_ID_PERSONAL=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
GOOGLE_SHEET_ID_CLIENTS=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# =============================================
# EVOLUTION API (WhatsApp)
# =============================================
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua-api-key
EVOLUTION_INSTANCE=nome-da-instancia
# Número do dono do agente (com DDI, sem +) — ex: 5511999999999
OWNER_PHONE=5511999999999

# =============================================
# CONTA AZUL
# =============================================
CONTA_AZUL_CLIENT_ID=seu-client-id
CONTA_AZUL_CLIENT_SECRET=seu-client-secret
# Após obter via OAuth, salve aqui (ou use o fluxo automático)
CONTA_AZUL_ACCESS_TOKEN=

# =============================================
# SERVIDOR
# =============================================
PORT=3000
# URL pública do servidor (para webhook do WhatsApp)
PUBLIC_URL=https://seu-dominio.com

# =============================================
# AGENDAMENTOS (formato cron: "0 8 * * *" = todo dia às 8h)
# =============================================
CRON_DAILY_CHECK="0 8 * * *"
CRON_WEEKLY_SUMMARY="0 9 * * 1"
